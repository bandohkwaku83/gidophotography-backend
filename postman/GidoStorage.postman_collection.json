						},
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/selections",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "selections"]
						},
						"description": "Select one raw photo. Response selection.raw uses the same URL rules as GET share (watermarked url when previews exist and setting is on). Use DELETE with clientSelectionId to deselect, or Sync selections to replace the whole set."
					}
				},
				{
					"name": "Client sync selections (PUBLIC)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"rawMediaIds\": [\"{{rawMediaId}}\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/selections/sync",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "selections", "sync"]
						},
						"description": "Replaces the client's picks with exactly this list of raw media ids (max 500). Returns selection[] with raw URLs following the same watermark rules as GET share."
					}
				},
				{
					"name": "Client remove selection (PUBLIC)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/selections/{{clientSelectionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "selections", "{{clientSelectionId}}"]
						},
						"description": "Deselect one photo. selection _id from GET gallery → selection[]."
					}
				},
				{
					"name": "Client submit selection (PUBLIC)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/selections/submit",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "selections", "submit"]
						},
						"description": "Locks further pick changes until photographer unlocks via PATCH /folders/:id/share."
					}
				},
				{
					"name": "Client locked final preview (PUBLIC)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/finals/{{finalMediaId}}/locked-preview",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "finals", "{{finalMediaId}}", "locked-preview"]
						},
						"description": "When the folder is payment-locked, finals[].url points here: returns a downscaled watermarked JPEG (not the original). Returns 404 when the gallery is not locked. Use as <img src> only."
					}
				},
				{
					"name": "Client download final (PUBLIC)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/share/{{shareIdentifier}}/finals/{{finalMediaId}}/download",
							"host": ["{{baseUrl}}"],
							"path": ["api", "share", "{{shareIdentifier}}", "finals", "{{finalMediaId}}", "download"]
						},
						"description": "Attachment download of one final. Use finals[].downloadUrl from the gallery GET, or this URL pattern."
					}
				}
			]
		}
	]
}
