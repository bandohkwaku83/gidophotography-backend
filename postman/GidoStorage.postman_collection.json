{
	"info": {
		"name": "GidoStorage Backend",
		"description": "Auth, clients, bookings (calendar), folders, dashboard, settings, share (public), SMS (Arkesel). Bookings: GET /api/bookings/meta, summary/week, list ?year=&month=, CRUD /api/bookings. Unpaid final SMS defaults, final-delivery upload fields, PATCH .../final-delivery/unlock. Raw watermarking when settings.watermarkPreviewImages is true.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "clientId",
			"value": "",
			"type": "string"
		},
		{
			"key": "bookingId",
			"value": "",
			"type": "string"
		},
		{
			"key": "folderId",
			"value": "",
			"type": "string"
		},
		{
			"key": "shareIdentifier",
			"value": "",
			"type": "string"
		},
		{
			"key": "rawMediaId",
			"value": "",
			"type": "string"
		},
		{
			"key": "selectionMediaId",
			"value": "",
			"type": "string"
		},
		{
			"key": "clientSelectionId",
			"value": "",
			"type": "string"
		},
		{
			"key": "finalMediaId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    if (data.token) {",
									"        pm.collectionVariables.set('token', data.token);",
									"        console.log('Token saved to collection variable.');",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"gidophotography@gmail.com\",\n    \"password\": \"Gid038271!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Logs in with email and password. On success, the returned JWT is automatically saved to the {{token}} collection variable and used by other requests."
					}
				},
				{
					"name": "Forgot password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"gidophotography@gmail.com\",\n    \"newPassword\": \"NewPass123!\",\n    \"confirmPassword\": \"NewPass123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/forgot-password",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"forgot-password"
							]
						},
						"description": "Resets a user's password by email. Body requires email, newPassword and confirmPassword."
					}
				},
				{
					"name": "Admin info",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/me",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"me"
							]
						},
						"description": "Returns the currently authenticated user. Requires a valid Bearer token."
					}
				},
				{
					"name": "Update profile (contact)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"contact\": \"233XXXXXXXXX\",\n    \"name\": \"Studio name\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "me"]
						},
						"description": "Updates the logged-in user. Optional fields: name, contact (Ghana-style phone for booking reminder SMS to the studio user). Omitted fields are unchanged."
					}
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set('token', '');",
									"    console.log('Token cleared from collection variable.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "logout"]
						},
						"description": "Logs out the current user. Adds the token to a server-side blacklist so it can no longer be used. Also clears the {{token}} collection variable."
					}
				}
			]
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get dashboard",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/dashboard",
							"host": ["{{baseUrl}}"],
							"path": ["api", "dashboard"]
						},
						"description": "Returns user, aggregate stats (clients & galleries), recent galleries (cover, title, client, status, dates), and a merged activity feed. Optional query: recentLimit (default 8), activityLimit (default 15)."
					}
				}
			]
		},
		{
			"name": "Usage",
			"item": [
				{
					"name": "Usage summary",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/usage/summary",
							"host": ["{{baseUrl}}"],
							"path": ["api", "usage", "summary"]
						},
						"description": "Aggregated storage (bytes) and by_category percentages for raws, selections, finals. Based on FolderMedia.size."
					}
				},
				{
					"name": "Usage by gallery",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/usage/galleries?sort_by=total_size&order=desc",
							"host": ["{{baseUrl}}"],
							"path": ["api", "usage", "galleries"],
							"query": [
								{ "key": "sort_by", "value": "total_size" },
								{ "key": "order", "value": "desc" }
							]
						},
						"description": "Per-folder usage with client name. Query: sort_by=total_size|name, order=asc|desc. Defaults: total_size + desc; name + asc."
					}
				}
			]
		},
		{
			"name": "SMS",
			"item": [
				{
					"name": "SMS meta (placeholders)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/sms/meta",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sms", "meta"]
						},
						"description": "Returns placeholders, recipient types, Arkesel flag, bulkSend, smsBulkDefaultClientName, smsBranding { prefixSet, suffixSet } (SMS_BRAND_PREFIX / SMS_BRAND_SUFFIX on server). Upload SMS uses SMS_NOTIFY_*; see folder upload requests."
					}
				},
				{
					"name": "Send SMS",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"recipientType\": \"all_clients\",\n    \"message\": \"Hi {{client_name}}, your gallery is ready: {{gallery_link}}\",\n    \"folderId\": \"{{folderId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/sms/send",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sms", "send"]
						},
						"description": "One Arkesel API call per request. For recipientType client, send clientId OR client OR selectedClientId (string id or { _id }). all_clients: {{client_name}} uses SMS_BULK_DEFAULT_CLIENT_NAME / \"there\". Placeholders {{event_date}}/{{gallery_link}} need folderId. See GET /api/sms/meta → singleClientIdFields."
					}
				},
				{
					"name": "List SMS messages",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/sms/messages?page=1&limit=10&search=&status=",
							"host": ["{{baseUrl}}"],
							"path": ["api", "sms", "messages"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "search", "value": "", "description": "Optional. Matches message, recipient name or phone." },
								{ "key": "status", "value": "", "description": "Optional: sent | failed | pending" }
							]
						},
						"description": "Paginated log for the Recent Messages UI (recipient, message, length, status, costGHS, timestamps). Each document includes trigger: manual | raw_upload | final_upload | final_delivery_unpaid | booking_reminder_client | booking_reminder_admin (manual is POST /api/sms/send; upload triggers are automatic after successful batches when SMS is enabled; booking reminders use a cron ~BOOKING_REMINDER_HOURS_BEFORE hours before startsAt)."
					}
				}
			]
		},
		{
			"name": "Clients",
			"item": [
				{
					"name": "Create client",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    if (data.client && data.client._id) {",
									"        pm.collectionVariables.set('clientId', data.client._id);",
									"        console.log('clientId saved:', data.client._id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Acme Studios\",\n    \"email\": \"contact@acme.com\",\n    \"contact\": \"+233200000000\",\n    \"location\": \"Accra, Ghana\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/clients",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients"]
						},
						"description": "Creates a new client. Required: name, contact, location. Optional: email. Saves the new client's id into the {{clientId}} collection variable for the other requests."
					}
				},
				{
					"name": "Get all clients",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/clients?search=",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients"],
							"query": [
								{ "key": "search", "value": "", "description": "Optional. Filters by name, email, contact or location (case-insensitive)." }
							]
						}
					}
				},
				{
					"name": "Get one client",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/clients/{{clientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients", "{{clientId}}"]
						}
					}
				},
				{
					"name": "Update client",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Acme Studios Ltd\",\n    \"contact\": \"+233200000111\",\n    \"location\": \"Kumasi, Ghana\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/clients/{{clientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients", "{{clientId}}"]
						},
						"description": "Send only the fields you want to change. Any of name, email, contact, location."
					}
				},
				{
					"name": "Delete client",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/clients/{{clientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients", "{{clientId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Bookings",
			"item": [
				{
					"name": "Booking meta (shoot types + legend)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/bookings/meta",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "meta"]
						},
						"description": "Returns shootTypes[] { id, label, color } for filters and calendar dots."
					}
				},
				{
					"name": "Bookings this week (count)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/bookings/summary/week",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "summary", "week"]
						},
						"description": "Sunday–Saturday in server local time: bookedCount, weekStartsAt, weekEndsAt."
					}
				},
				{
					"name": "List bookings (month or range)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/bookings?year=2026&month=5&type=",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings"],
							"query": [
								{ "key": "year", "value": "2026", "description": "Use with month for calendar grid." },
								{ "key": "month", "value": "5", "description": "1–12" },
								{ "key": "type", "value": "", "description": "Optional: Wedding | Portraits | Outdoor | Birthday | Graduation | Commercial | Other" },
								{ "key": "from", "value": "", "description": "Alternative: ISO range with to= (omit year/month)." },
								{ "key": "to", "value": "", "description": "ISO end date/time." }
							]
						},
						"description": "bookings[] sorted by startsAt; each includes color for UI. Or ?from=&to= instead of year/month."
					}
				},
				{
					"name": "Create booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const d = pm.response.json();",
									"    if (d.booking && d.booking._id) {",
									"        pm.collectionVariables.set('bookingId', d.booking._id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Styled editorial\",\n    \"clientId\": \"{{clientId}}\",\n    \"date\": \"2026-05-29\",\n    \"shootType\": \"Other\",\n    \"start\": \"09:00 AM\",\n    \"end\": \"\",\n    \"location\": \"Downtown loft\",\n    \"description\": \"Magazine pitch\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings"]
						},
						"description": "clientId required (Mongo id from GET /api/clients). No phone field — contact is on booking.client.contact when populated. date: YYYY-MM-DD or DD/MM/YYYY. start/end: HH:mm or h:mm AM/PM, or startsAt/endsAt ISO. Reminder SMS: server cron ~24h before startsAt (BOOKING_REMINDER_* env); client gets SMS from client.contact; admin from PATCH /api/auth/me contact or BOOKING_REMINDER_ADMIN_PHONE."
					}
				},
				{
					"name": "Get one booking",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}"]
						}
					}
				},
				{
					"name": "Update booking",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Styled editorial (updated)\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}"]
						}
					}
				},
				{
					"name": "Delete booking",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Settings",
			"item": [
				{
					"name": "Get settings",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/settings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "settings"]
						},
						"description": "Returns defaultCoverImageUrl, watermarkPreviewImages (boolean), updatedAt. When watermark is on, new raw uploads get a generated watermarked preview file (see folder raw upload / GET folder / GET share)."
					}
				},
				{
					"name": "Update default cover image",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "defaultCoverImage",
									"type": "file",
									"src": [],
									"description": "Image file to use as the system-wide default folder cover."
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/settings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "settings"]
						},
						"description": "Uploads a default cover image. Use form-data with key 'defaultCoverImage' (type: File)."
					}
				},
				{
					"name": "Toggle watermark preview",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"watermarkPreviewImages\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/settings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "settings"]
						},
						"description": "Turns watermarkPreviewImages on or off (JSON body). When true, each subsequent POST .../media/raw generates a companion JPEG (*-wm.jpg): images get three large diagonal PREVIEW stamps (no event title); videos get the same plus fixed \"Video — preview only\" at the bottom. Admin GET folder lists originals as url plus displayUrl when generated. Public GET /api/share/:id serves watermarked URLs as url on uploads and nested selection.raw when a display file exists. Existing uploads are unchanged until re-uploaded."
					}
				},
				{
					"name": "Update settings (cover + watermark together)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "defaultCoverImage", "type": "file", "src": [], "description": "Optional image file." },
								{ "key": "watermarkPreviewImages", "value": "true", "type": "text", "description": "Optional. true/false." }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/settings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "settings"]
						},
						"description": "Combined update. You can send any subset of fields; only what you include changes. If watermarkPreviewImages is true, enable watermark generation for new raw uploads (see Toggle watermark preview)."
					}
				},
				{
					"name": "Reset defaults",
					"request": {
						"method": "POST",
